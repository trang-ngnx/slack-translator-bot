# ── Slack App Credentials ──────────────────────────────────────────────────
# From api.slack.com/apps → Your App → Basic Information
SLACK_SIGNING_SECRET=your_signing_secret_here

# From OAuth & Permissions → Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Only needed if using Socket Mode (set SOCKET_MODE=true)
# From Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here
SOCKET_MODE=false

# ── Anthropic Claude API ───────────────────────────────────────────────────
# From console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Your Config ────────────────────────────────────────────────────────────
# Your Slack user ID (open Slack → click your profile → copy Member ID)
MY_SLACK_USER_ID=U012AB3CD

# Comma-separated channel IDs to monitor for incoming translations
# Find channel ID: right-click channel → View channel details → scroll to bottom
MONITORED_CHANNEL_IDS=C012AB3CD,C045EF6GH

# Comma-separated user IDs to monitor in 1:1 DMs
# These are the OTHER person's user IDs (not yours)
# Find user ID: click their profile → ⋮ More → Copy Member ID
MONITORED_DM_USER_IDS=U012AB3CD,U045EF6GH

# Default target language for /send outgoing messages
OUTGOING_LANGUAGE=English

# Optional: per-channel outgoing language (JSON format)
# If a channel speaks Japanese, your /send message will be translated to Japanese in that channel
CHANNEL_LANGUAGES={"C012AB3CD":"Japanese","C045EF6GH":"French"}

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
