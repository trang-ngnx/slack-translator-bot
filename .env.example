# ── Slack App Credentials ──────────────────────────────────────────────────
# From api.slack.com/apps → Your App → Basic Information
SLACK_SIGNING_SECRET=your_signing_secret_here

# From OAuth & Permissions → Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Only needed if using Socket Mode (set SOCKET_MODE=true)
# From Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here
SOCKET_MODE=false

# ── Redis (persistent storage) ────────────────────────────────────────────
# Free at upstash.com — create a database and copy the URL
REDIS_URL=redis://default:yourpassword@your-endpoint.upstash.io:6379

# ── Translation ───────────────────────────────────────────────────────────
# Incoming auto-translations use Google Translate's free endpoint — no key needed.
#
# Optional: Claude-powered OUTGOING translation (recommended). When set,
# /ed send and thread replies are translated by Claude with the surrounding
# thread as context — much more natural than Google's word-by-word output.
# Get a key at https://platform.claude.com → API Keys.
# If unset (or a request fails), outgoing messages fall back to Google.
ANTHROPIC_API_KEY=
# Optional: override the Claude model (default: claude-opus-4-8)
CLAUDE_MODEL=

# ── Your Config ────────────────────────────────────────────────────────────
# Comma-separated Slack user IDs to seed as initial subscribers (auto-translation recipients)
# Users can also self-register anytime with /ed join
# Find user ID: click profile → ⋮ More → Copy Member ID
SUBSCRIBER_USER_IDS=U012AB3CD,U045EF6GH

# Comma-separated channel IDs to monitor for incoming translations
# Find channel ID: right-click channel → View channel details → scroll to bottom
MONITORED_CHANNEL_IDS=C012AB3CD,C045EF6GH
# Note: channels are also watched automatically as soon as the bot is added
# to them — this is only needed to seed channels the bot already joined
# before that feature was enabled, or you prefer to manage it via config.

# Default target language for /send outgoing messages
OUTGOING_LANGUAGE=English

# Optional: per-channel outgoing language (JSON format)
# If a channel speaks Japanese, your /send message will be translated to Japanese in that channel
CHANNEL_LANGUAGES={"C012AB3CD":"Japanese","C045EF6GH":"French"}

# Optional: comma-separated brand/product/person names that should never be translated
PROTECTED_TERMS=YourBrand,ClientName

# Optional: link to an internal onboarding canvas/doc — shown in /ed newbie
# and the Home tab if set, omitted entirely otherwise
CANVAS_URL=

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
